{
  "info": {
    "name": "MotoSpeed API - Mercado Pago",
    "_postman_id": "motospeed-mp-collection",
    "description": "Colección de Postman para probar la integración de Mercado Pago en MotoSpeed",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "API Info",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        }
      }
    },
    {
      "name": "Mercado Pago",
      "item": [
        {
          "name": "1. Crear Preferencia Simple",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"title\": \"Casco Moto AGV K1\",\n      \"unit_price\": 150000,\n      \"quantity\": 1\n    },\n    {\n      \"title\": \"Guantes Alpinestars\",\n      \"unit_price\": 45000,\n      \"quantity\": 2\n    }\n  ],\n  \"payer\": {\n    \"name\": \"Juan\",\n    \"surname\": \"Perez\",\n    \"email\": \"test_user_123456@testuser.com\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mercadopago/create-preference",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mercadopago", "create-preference"]
            },
            "description": "Crea una preferencia de pago directamente con items. Útil para pruebas rápidas.\n\nRespuesta exitosa:\n```json\n{\n  \"success\": true,\n  \"data\": {\n    \"id\": \"123456789-xxxx\",\n    \"init_point\": \"https://www.mercadopago.cl/checkout/v1/redirect?pref_id=xxx\",\n    \"sandbox_init_point\": \"https://sandbox.mercadopago.cl/checkout/v1/redirect?pref_id=xxx\"\n  }\n}\n```"
          }
        },
        {
          "name": "2. Crear Orden desde Carrito",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "description": "Opcional - Si el usuario está autenticado"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cart\": [\n    {\n      \"productId\": 1,\n      \"quantity\": 1\n    },\n    {\n      \"productId\": 2,\n      \"quantity\": 2\n    }\n  ],\n  \"payer\": {\n    \"name\": \"Juan Perez\",\n    \"email\": \"test_user_123456@testuser.com\",\n    \"phone\": \"912345678\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mercadopago/create-order",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mercadopago", "create-order"]
            },
            "description": "Crea una orden desde el carrito usando productos de la base de datos.\n\nVerifica stock y crea registros en la tabla orders."
          }
        },
        {
          "name": "3. Consultar Pago",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/mercadopago/payment/:paymentId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mercadopago", "payment", ":paymentId"],
              "variable": [
                {
                  "key": "paymentId",
                  "value": "1234567890",
                  "description": "ID del pago de Mercado Pago"
                }
              ]
            },
            "description": "Consulta el estado de un pago por su ID de Mercado Pago."
          }
        },
        {
          "name": "4. Webhook (Simular)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"payment\",\n  \"data\": {\n    \"id\": \"1234567890\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/mercadopago/webhook",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mercadopago", "webhook"]
            },
            "description": "Simula una notificación de Mercado Pago.\n\nEn producción, MP envía estas notificaciones automáticamente."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registrar Usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Perez\",\n  \"email\": \"juan@ejemplo.com\",\n  \"password\": \"password123\",\n  \"telefono\": \"912345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@ejemplo.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Perfil (requiere auth)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Listar Productos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "Producto por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Crear Producto (requiere auth)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Casco AGV K1\",\n  \"slug\": \"casco-agv-k1\",\n  \"descripcion\": \"Casco de alta calidad para moto\",\n  \"category_id\": 1,\n  \"precio\": 150000,\n  \"precio_oferta\": 135000,\n  \"stock\": 10,\n  \"marca\": \"AGV\",\n  \"destacado\": true,\n  \"activo\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Mis Órdenes (requiere auth)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/orders/my-orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "my-orders"]
            }
          }
        },
        {
          "name": "Orden por ID (requiere auth)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/orders/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "1"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
